<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- The whole reason this process exists: Server GC is a process-wide CLR setting fixed at
       startup, and FieldWorks.exe (Workstation GC, for UI responsiveness) can't offer it. See
       RUSTIFY-fieldworks-worker-design.md §1-2. concurrent="true" additionally overlaps
       background collections with app threads; background Gen2 collections still contend, but
       far less than Workstation GC's single-collector-thread stop-the-world. -->
  <runtime>
    <gcServer enabled="true" />
    <gcConcurrent enabled="true" />
  </runtime>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
</configuration>
